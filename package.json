{
    "name": "asma-mfw-esmloader",
    "version": "0.1.0",
    "description": "Native-ESM widget loader — the transport-agnostic successor to asma-qiankun-react-loader. Loads widgets by import()ing an ES module that exports mount(); createDualLoader dispatches per-app between this and the legacy qiankun loader with no global flag.",
    "type": "module",
    "license": "Proprietary",
    "exports": {
        ".": "./lib/index.js",
        "./contract": "./lib/contract.js"
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "build": "tsc",
        "check": "tsc --noEmit",
        "test": "node --import tsx --test \"src/**/*.test.ts\""
    },
    "peerDependencies": {
        "react": "^18 || ^19",
        "react-dom": "^18 || ^19"
    },
    "pnpm": {
        "onlyBuiltDependencies": ["esbuild"]
    },
    "devDependencies": {
        "@types/react": "^18 || ^19",
        "@types/react-dom": "^18 || ^19",
        "jsdom": "^29.1.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tsx": "^4.7.1",
        "typescript": "^5.6.3"
    }
}

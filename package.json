{
    "name": "asma-mfw-esmloader",
    "version": "0.1.0",
    "description": "Native-ESM widget loader — the transport-agnostic successor to asma-qiankun-react-loader. Loads widgets by import()ing an ES module that exports mount(); createDualLoader dispatches per-app between this and the legacy qiankun loader with no global flag.",
    "type": "module",
    "license": "MIT",
    "exports": {
        ".": "./lib/index.js",
        "./contract": "./lib/contract.js",
        "./vite": "./lib/vite.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Carasent-ASMA/asma-mfw-esmloader.git"
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "build": "pnpm ts:check",
        "ts:check": "tsc",
        "test": "node --import tsx --test \"src/**/*.test.ts\"",
        "test:types": "pnpm ts:check -p type-tests/tsconfig.json"
    },
    "peerDependencies": {
        "react": "^18 || ^19",
        "react-dom": "^18 || ^19"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "@types/react": "^18 || ^19",
        "@types/react-dom": "^18 || ^19",
        "@typescript/native": "npm:typescript@7.0.2",
        "jsdom": "^29.1.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tsx": "^4.7.1",
        "typescript": "npm:@typescript/typescript6@6.0.2"
    }
}
